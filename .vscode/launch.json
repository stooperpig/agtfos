{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Bot",
            "program": "${workspaceFolder}/server/dist/debug-bot.js",
            "cwd": "${workspaceFolder}/server"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Simulation",
            "program": "${workspaceFolder}/server/dist/debug-simulation.js",
            "cwd": "${workspaceFolder}/server"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Combat",
            "program": "${workspaceFolder}/server/dist/debug-combat.js",
            "cwd": "${workspaceFolder}/server"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}\\server\\jest.config.js",
            "outFiles": [
                "${workspaceFolder}/**/*.js"
            ]
        },
        {
            "name": "Debug Jest Server",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}\\node_modules\\.bin\\jest",
            "cwd": "${workspaceFolder}\\server",
            "args": [
                "--runTestsByPath",
                "${file}",
                "--config",
                "${workspaceFolder}\\server\\jest.config.js",
                "--coverage",
                "false"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "windows": {
                "program": "${workspaceFolder}\\node_modules\\jest\\bin\\jest.js"
            }
        },
        {
            "name": "Debug Jest Client",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}\\node_modules\\.bin\\jest",
            "cwd": "${workspaceFolder}\\client",
            "args": [
                "--runTestsByPath",
                "${file}",
                "--config",
                "${workspaceFolder}\\client\\jest.config.mjs",
                "--coverage",
                "false"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "windows": {
                "program": "${workspaceFolder}\\node_modules\\jest\\bin\\jest.js"
            }
        },
        {
            "name": "Debug React in Chrome",
            "type": "pwa-chrome",
            "request": "launch",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}/client/src",
            "sourceMaps": true
        }
    ]
}