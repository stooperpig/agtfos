{
  "compilerOptions": {
    "target": "ESNext", 
    "module": "commonjs",
    "moduleResolution": "node",
    "jsx": "react",
    "outDir": "./dist", 
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true, 
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*", "tests/shared/utils/map-utils.test.ts"  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}