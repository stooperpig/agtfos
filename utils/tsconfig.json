{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,

    "types": ["node"],          // 👈 important
    "skipLibCheck": true        // 👈 avoids @types/node noise
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules"]
}